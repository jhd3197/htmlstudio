{
  "name": "htmlstudio",
  "version": "0.4.0",
  "description": "HTML-source-of-truth visual editor primitives (tag, bridge, patch) — the post-generation edit layer for AgentSite and other AI website builders.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./bridge": {
      "types": "./dist/bridge.d.ts",
      "import": "./dist/bridge.js"
    },
    "./tagger": {
      "types": "./dist/tagger.d.ts",
      "import": "./dist/tagger.js"
    },
    "./patches": {
      "types": "./dist/patches.d.ts",
      "import": "./dist/patches.js"
    },
    "./query": {
      "types": "./dist/query.d.ts",
      "import": "./dist/query.js"
    },
    "./blocks": {
      "types": "./dist/blocks.d.ts",
      "import": "./dist/blocks.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo": "node demo/serve.mjs",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "node-html-parser": "^6.1.13"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "visual-editor",
    "html",
    "wysiwyg",
    "ai",
    "agentsite",
    "ai-website-builder",
    "iframe",
    "live-edit",
    "postmessage",
    "contenteditable"
  ],
  "author": "Juan Denis",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
